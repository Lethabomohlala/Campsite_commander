<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.CampsiteCommander" parent="Theme.Material3.DayNight.NoActionBar">

        <item name="colorPrimary">@color/camping_green</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/camping_green_dark</item>
        <item name="colorSecondary">@color/camping_brown</item>
        <item name="android:windowBackground">@color/camping_bg</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="Theme.CampsiteCommander" parent="Base.Theme.CampsiteCommander" />

    <style name="Theme.CampsiteCommander.Dialog" parent="Theme.Material3.DayNight.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">true</item>
    </style>
</resources>